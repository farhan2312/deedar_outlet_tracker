# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit real secrets.

# ── Azure Postgres connection string ──────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# Azure Postgres requires SSL (sslmode=require).
DATABASE_URL=postgres://user:password@your-server.postgres.database.azure.com:5432/deedar?sslmode=require

# ── Session signing secret ────────────────────────────────────────────
# Any long random string (32+ chars). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=replace-with-a-long-random-secret

# ── First admin account (used only by `npm run create-admin`) ─────────
ADMIN_NAME=Admin
ADMIN_PHONE=9999999999
ADMIN_PASSWORD=change-this-strong-password

# Public app URL (optional)
NEXT_PUBLIC_APP_URL=http://localhost:3000
